# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/crm_db"

# Google Drive webhook token
GDRIVE_WEBHOOK_TOKEN=change-this-to-a-random-secret

# Python extraction pipeline (inside Docker: /app/extraction)
PYTHON_VENV_PATH=/usr/bin/python3
EXTRACTION_DIR=/app/extraction

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# Notify cron endpoint secret
NOTIFY_SECRET=your-random-notify-secret

# Google OAuth — NextAuth (restrict to @sakww.com)
AUTH_SECRET=your-random-auth-secret
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
