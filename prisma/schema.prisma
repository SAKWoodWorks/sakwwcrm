generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Salesperson {
  id          Int        @id @default(autoincrement())
  name        String
  channel     String?
  lineUserId  String?    @map("line_user_id")
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")

  documents   Document[]
  managedCustomers Customer[] @relation("AccountManager")

  @@map("salespersons")
}

model Customer {
  id               Int          @id @default(autoincrement())
  name             String
  taxId            String?      @unique @map("tax_id")
  vatRegistered    Boolean      @default(true) @map("vat_registered")
  type             String?
  status           String       @default("not_purchase_yet")
  address          String?
  province         String?
  phone            String?
  email            String?
  lineId           String?      @map("line_id")
  otherId          String?      @map("other_id")
  salespersonId    Int?         @map("salesperson_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  salesperson      Salesperson? @relation("AccountManager", fields: [salespersonId], references: [id])
  documents        Document[]

  @@map("customers")
}

model Product {
  id                   Int       @id @default(autoincrement())
  skuCode              String    @unique @map("sku_code")
  category             String?
  grade                String?
  thickness            Decimal?  @db.Decimal(8, 2)
  width                Decimal?  @db.Decimal(8, 2)
  length               Decimal?  @db.Decimal(8, 2)
  fullName             String    @map("full_name")
  weight               Decimal?  @db.Decimal(8, 3)
  volume               Decimal?  @db.Decimal(10, 4)
  wsCost               Decimal?  @map("ws_cost") @db.Decimal(12, 2)
  rtCost               Decimal?  @map("rt_cost") @db.Decimal(12, 2)
  dateLastCostAdj      DateTime? @map("date_last_cost_adj") @db.Date
  dateLastInvoice      DateTime? @map("date_last_invoice") @db.Date
  totalQtyInvoiced     Decimal?  @default(0) @map("total_qty_invoiced") @db.Decimal(12, 3)
  totalAmountInvoiced  Decimal?  @default(0) @map("total_amount_invoiced") @db.Decimal(14, 2)
  totalQtyQuoted       Decimal?  @default(0) @map("total_qty_quoted") @db.Decimal(12, 3)
  totalAmountQuoted    Decimal?  @default(0) @map("total_amount_quoted") @db.Decimal(14, 2)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  documentItems        DocumentItem[]
  transformRules       ProductTransformRule[]

  @@map("products")
}

model ProductTransformRule {
  id        Int     @id @default(autoincrement())
  pattern   String
  productId Int     @map("product_id")
  priority  Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_transform_rules")
  @@index([productId, priority])
}

model Document {
  id             Int            @id @default(autoincrement())
  docType        String         @map("doc_type")
  docNumber      String         @map("doc_number")
  docDate        DateTime       @map("doc_date") @db.Date
  channel        String?
  salespersonId  Int?           @map("salesperson_id")
  paymentStatus  String?        @map("payment_status")
  refDocNumber   String?        @map("ref_doc_number")
  customerId     Int?           @map("customer_id")
  subtotal       Decimal?       @db.Decimal(12, 2)
  vat            Decimal?       @db.Decimal(12, 2)
  total          Decimal?       @db.Decimal(12, 2)
  notes          String?
  gdriveFileId   String?        @unique @map("gdrive_file_id")
  gdriveFilename String?        @map("gdrive_filename")
  createdAt      DateTime       @default(now()) @map("created_at")

  salesperson    Salesperson?   @relation(fields: [salespersonId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id])
  items          DocumentItem[]

  @@map("documents")
}

model DocumentItem {
  id          Int       @id @default(autoincrement())
  documentId  Int       @map("document_id")
  lineNo      Int?      @map("line_no")
  description String?
  quantity    Decimal?  @db.Decimal(10, 3)
  unit        String?
  unitPrice   Decimal?  @map("unit_price") @db.Decimal(12, 2)
  total       Decimal?  @db.Decimal(12, 2)
  productId   Int?      @map("product_id")

  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("document_items")
}

model SyncLog {
  id           Int       @id @default(autoincrement())
  gdriveFileId String?   @map("gdrive_file_id")
  filename     String?
  status       String
  errorMsg     String?   @map("error_msg")
  processedAt  DateTime  @default(now()) @map("processed_at")

  @@map("sync_log")
}
